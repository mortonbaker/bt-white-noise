// Copy to secrets.h on atlas01 and fill in. secrets.h is gitignored.
//
//   cp include/secrets.h.example include/secrets.h
//   nano include/secrets.h

#pragma once

#define WIFI_SSID       "your-ssid-here"
#define WIFI_PASSWORD   "your-wifi-password-here"

// MP3 URL the ESP32 pulls audio from. Pointed at atlas01's HTTP server
// (set up by scripts/serve.sh). Use the LAN IP, not .local, so we don't
// depend on mDNS resolution from the ESP32.
#define MP3_URL         "http://192.168.0.143:8080/current.mp3"

// Bluetooth name of the Bose SoundLink Mini. Common values:
//   "Bose Mini II SoundLink"
//   "Bose SoundLink Mini II"
//   "Bose SoundLink Mini II SE"
// If unsure, leave the placeholder, flash, and watch the serial log —
// it will list every nearby BT name. Then update and re-flash.
#define BT_DEVICE_NAME  "Bose Mini II SoundLink"

// Playback volume (0.0 - 1.0). 0.6 is a good starting point for white noise.
#define VOLUME          0.6f
